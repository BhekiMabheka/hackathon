# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# ── Data (DVC-tracked — never commit raw/processed data to git) ───────────────
data/raw/
data/interim/
data/processed/
data/external/
# ↳ Exceptions: files needed by the Streamlit Cloud dashboard
!data/raw/loan_dataset_20000.csv
!data/processed/train_features.parquet
!data/processed/test_features.parquet
!data/processed/feature_meta.json

# ── Model artefacts ───────────────────────────────────────────────────────────
outputs/models/*.pkl
outputs/models/*.joblib
# ↳ Exception: trained model needed by Streamlit Cloud dashboard
!outputs/models/model.pkl
!outputs/models/oof_predictions.parquet

# ── Report artefacts (small JSON/parquet — needed by dashboard) ───────────────
!outputs/reports/oof_metrics.json
!outputs/reports/cv_metrics.json
!outputs/reports/feature_importance.parquet

# ── Sensitive ────────────────────────────────────────────────────────────────
.env

# ── MLflow ────────────────────────────────────────────────────────────────────
outputs/mlflow.db
outputs/artifacts/

# ── Hydra ────────────────────────────────────────────────────────────────────
outputs/hydra/

# ── Tools ────────────────────────────────────────────────────────────────────
.ruff_cache/
.mypy_cache/
.pytest_cache/
htmlcov/
.coverage
*.log

# For projects that use the Waf build system: https://waf.io/
# Dot-hidden on Unix-like systems
.waf-*-*/
.waf3-*-*/
# Hidden directory on Windows (no dot)
waf-*-*/
waf3-*-*/
# Lockfile
.lock-waf_*_build
