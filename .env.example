# Copy to .env and fill in values. Never commit .env.

# MLflow tracking
MLFLOW_TRACKING_URI=sqlite:///outputs/mlflow.db
MLFLOW_EXPERIMENT_NAME=nedbank-masters-2026

# DVC remote (S3 example — swap for your actual remote)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=af-south-1
DVC_REMOTE_URL=s3://your-bucket/nedbank-dvc

# Zindi / competition API
ZINDI_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json    # json | text

# Reproducibility
GLOBAL_SEED=42
